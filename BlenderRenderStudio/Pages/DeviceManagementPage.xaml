<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BlenderRenderStudio.Pages.DeviceManagementPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BlenderRenderStudio.Models">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition FromHorizontalOffset="60" />
        </TransitionCollection>
    </Page.Transitions>

    <Grid Padding="32,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid>
            <StackPanel>
                <TextBlock Text="设备管理" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="SubtitleText" FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8"
                        VerticalAlignment="Top">
                <Button x:Name="ScanButton" Click="ScanLan_Click" ToolTipService.ToolTip="广播扫描局域网内的在线设备">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon x:Name="ScanIcon" Glyph="&#xE894;" FontSize="14" />
                        <TextBlock x:Name="ScanText" Text="扫描局域网" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 扫描状态提示 -->
        <InfoBar x:Name="ScanInfoBar" Grid.Row="1" IsOpen="False" IsClosable="True" />

        <!-- 设备列表 -->
        <ListView x:Name="DeviceListView" Grid.Row="2"
                  SelectionMode="None" Padding="0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:RemoteDevice">
                    <Border CornerRadius="8" BorderThickness="1" Padding="16,12"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Border.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="调整权重" Icon="Repair"
                                                Tag="{x:Bind Id}" Click="AdjustWeight_Click" />
                                <MenuFlyoutItem Text="移除设备" Icon="Delete"
                                                Tag="{x:Bind Id}" Click="RemoveDevice_Click" />
                            </MenuFlyout>
                        </Border.ContextFlyout>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 设备图标 -->
                            <FontIcon Glyph="&#xE7F8;" FontSize="28"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <!-- 设备信息 -->
                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="14" />
                                    <Border CornerRadius="3" Padding="6,1"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                        <TextBlock Text="{x:Bind DisplayAddress}" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{x:Bind HardwareInfo}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>

                            <!-- 状态 + 权重 -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                        HorizontalAlignment="Right" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                    <Ellipse Width="8" Height="8" Fill="{x:Bind Status, Converter={StaticResource DeviceStatusBrush}}" />
                                    <TextBlock Text="{x:Bind StatusText}" FontSize="12" />
                                </StackPanel>
                                <TextBlock FontSize="11" HorizontalAlignment="Right"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="权重: " /><Run Text="{x:Bind PerformanceWeight}" />
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 底部：手动添加 -->
        <Border Grid.Row="3" CornerRadius="8" Padding="16,12"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="80" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE710;" FontSize="14" VerticalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBox x:Name="ManualIpBox" Grid.Column="1" PlaceholderText="IP 地址 (如 192.168.1.100)"
                         FontSize="13" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text=":" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBox x:Name="ManualPortBox" Grid.Column="3" Text="19821"
                         FontSize="13" VerticalAlignment="Center" />
                <Button Grid.Column="4" Content="添加" Click="AddDevice_Click"
                        Style="{StaticResource AccentButtonStyle}" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>

    <Page.Resources>
        <local:DeviceStatusToBrushConverter x:Key="DeviceStatusBrush"
            xmlns:local="using:BlenderRenderStudio.Converters" />
    </Page.Resources>
</Page>
