<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BlenderRenderStudio.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition FromHorizontalOffset="80" />
        </TransitionCollection>
    </Page.Transitions>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="32,24" Spacing="4" MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

            <!-- Blender 路径 -->
            <TextBlock Text="Blender 路径" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="BlenderPathBox" FontSize="12" PlaceholderText="点击浏览或自动检测" />
                <Button Grid.Column="1" Content="浏览" Click="BrowseBlender_Click" />
                <Button Grid.Column="2" Content="自动检测" Click="AutoDetect_Click" />
            </Grid>
            <TextBlock x:Name="DetectStatusText" FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />

            <MenuFlyoutSeparator Margin="0,12" />

            <!-- 界面 -->
            <TextBlock Text="界面" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
            <ToggleSwitch x:Name="ShowLogToggle" Header="默认显示日志面板" Toggled="ShowLog_Toggled" />

            <MenuFlyoutSeparator Margin="0,12" />

            <!-- 分布式渲染 -->
            <TextBlock Text="分布式渲染" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
            <ToggleSwitch x:Name="RemoteWorkerToggle" Header="允许接收远程渲染任务"
                          OnContent="已启用（其他设备可向本机分配渲染任务）" OffContent="已关闭"
                          Toggled="RemoteWorker_Toggled" />
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                <TextBox x:Name="DeviceNameBox" Header="设备名称" Width="200" FontSize="13"
                         TextChanged="DeviceName_Changed" />
                <NumberBox x:Name="NetworkPortBox" Header="端口" Width="100"
                           Minimum="1024" Maximum="65535" SpinButtonPlacementMode="Hidden"
                           ValueChanged="NetworkPort_Changed" />
            </StackPanel>

            <MenuFlyoutSeparator Margin="0,12" />

            <!-- 系统 -->
            <TextBlock Text="系统" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
            <ToggleSwitch x:Name="AutoStartToggle" Header="开机自启动" Toggled="AutoStart_Toggled" />

            <MenuFlyoutSeparator Margin="0,12" />

            <!-- 缓存 -->
            <TextBlock Text="缓存" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="全局缩略图缓存" />
                    <TextBlock x:Name="CacheSizeText" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <Button Grid.Column="1" Content="清除全部缓存" Click="ClearCache_Click" VerticalAlignment="Center" />
            </Grid>

            <MenuFlyoutSeparator Margin="0,12" />

            <!-- 关于 -->
            <TextBlock Text="关于" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
            <TextBlock Text="Blender Render Studio v1.0" />
            <TextBlock Text="WinUI 3 / .NET 8 — 批量渲染管理工具"
                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
