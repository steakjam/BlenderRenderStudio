<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BlenderRenderStudio.Pages.ProjectWorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:BlenderRenderStudio.Converters"
    xmlns:models="using:BlenderRenderStudio.Models">

    <Page.Resources>
        <converters:FrameStatusToBrushConverter x:Key="StatusBrush" />
        <converters:FrameStatusToCardBrushConverter x:Key="CardBrush" />
        <converters:FrameStatusToOpacityConverter x:Key="StatusOpacity" />
        <converters:FrameStatusToRingVisibilityConverter x:Key="RingVisibility" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition FromHorizontalOffset="60" />
        </TransitionCollection>
    </Page.Transitions>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════ 左侧面板：项目参数 + 控制 ═══════ -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="16,12" Spacing="4">

                        <!-- 项目标题 -->
                        <TextBlock x:Name="ProjectTitle" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,8" />

                        <!-- 文件与输出 -->
                        <TextBlock Text="文件与输出" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />

                        <StackPanel Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="Blend 文件" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="BlendFileBox" FontSize="12" PlaceholderText="选择 .blend 文件"
                                         Text="{x:Bind ViewModel.BlendFilePath, Mode=TwoWay}"
                                         IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                <Button Grid.Column="1" Content="..." Click="BrowseBlendFile_Click"
                                        IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="输出路径" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="OutputPathBox" FontSize="12" PlaceholderText="默认跟随工程目录"
                                         Text="{x:Bind ViewModel.OutputPath, Mode=TwoWay}"
                                         IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                <Button Grid.Column="1" Content="..." Click="BrowseOutputPath_Click"
                                        IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>

                        <StackPanel Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="文件名前缀" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBox FontSize="12" PlaceholderText="frame_"
                                     Text="{x:Bind ViewModel.OutputPrefix, Mode=TwoWay}"
                                     IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                        </StackPanel>

                        <StackPanel Spacing="4" Margin="0,0,0,4">
                            <TextBlock Text="输出类型" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="OutputTypeCombo" HorizontalAlignment="Stretch"
                                      SelectedIndex="{x:Bind ViewModel.SelectedOutputTypeIndex, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}">
                                <ComboBoxItem Content="图片序列" />
                                <ComboBoxItem Content="视频" />
                                <ComboBoxItem Content="单帧" />
                            </ComboBox>
                        </StackPanel>

                        <MenuFlyoutSeparator Margin="0,8" />

                        <!-- 渲染范围 -->
                        <TextBlock Text="渲染范围" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />
                        <Grid ColumnSpacing="12" RowSpacing="8"
                              Visibility="{x:Bind ViewModel.ShowFrameRange, Mode=OneWay}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <NumberBox Header="起始帧" Value="{x:Bind ViewModel.StartFrame, Mode=TwoWay}" Minimum="0"
                                       IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                            <NumberBox Grid.Column="1" Header="结束帧" Value="{x:Bind ViewModel.EndFrame, Mode=TwoWay}" Minimum="0"
                                       IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                        </Grid>

                        <NumberBox Header="帧号" Value="{x:Bind ViewModel.SingleFrameNumber, Mode=TwoWay}" Minimum="0"
                                   IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.IsSingleFrame, Mode=OneWay}" />

                        <NumberBox Header="批大小" Value="{x:Bind ViewModel.BatchSize, Mode=TwoWay}" Minimum="1" Maximum="9999"
                                   IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.ShowBatchSize, Mode=OneWay}" Margin="0,8,0,0" />

                        <MenuFlyoutSeparator Margin="0,8" />

                        <!-- 高级设置折叠 -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="高级设置" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            </Expander.Header>
                            <StackPanel Spacing="12" Padding="0,8">
                                <TextBlock Text="内存管理" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <NumberBox Header="阈值 %" Value="{x:Bind ViewModel.MemoryThreshold, Mode=TwoWay}" Minimum="50" Maximum="99"
                                               SpinButtonPlacementMode="Inline" IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                    <NumberBox Grid.Column="1" Header="轮询(秒)" Value="{x:Bind ViewModel.MemoryPollSeconds, Mode=TwoWay}"
                                               Minimum="0.5" Maximum="60" SpinButtonPlacementMode="Inline"
                                               IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                </Grid>
                                <ToggleSwitch Header="崩溃自动重启" IsOn="{x:Bind ViewModel.AutoRestartOnCrash, Mode=TwoWay}"
                                              IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                <ToggleSwitch Header="启用黑帧检测" IsOn="{x:Bind ViewModel.EnableBlackFrameDetection, Mode=TwoWay}" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>

                <!-- 控制按钮 -->
                <Border Grid.Row="1" BorderThickness="0,1,0,0"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" Padding="16,10">
                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.StartCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                    <TextBlock Text="开始渲染" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" HorizontalAlignment="Stretch"
                                    Command="{x:Bind ViewModel.StopCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE71A;" FontSize="14" />
                                    <TextBlock Text="停止" />
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Button HorizontalAlignment="Stretch" Click="AddToQueue_Click"
                                ToolTipService.ToolTip="将项目加入渲染队列，可在队列页查看进度">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="加入渲染队列" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ 右侧面板：状态 + 预览 + 时间轴 + 日志 ═══════ -->
        <Grid Grid.Column="1" Padding="16,12" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 状态区 -->
            <StackPanel Spacing="6">
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ProgressBar Value="{x:Bind ViewModel.OverallProgress, Mode=OneWay}" Maximum="100"
                             Height="6" CornerRadius="3" />
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="总进度" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock><Run Text="{x:Bind ViewModel.OverallProgressText, Mode=OneWay}" /><Run Text="%" /></TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="当前帧" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock><Run Text="{x:Bind ViewModel.CurrentFrame, Mode=OneWay}" /></TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="已完成" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CompletedFrames, Mode=OneWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="预计剩余" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.EstimatedRemaining, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- 预览区 -->
            <Grid Grid.Row="1">
                <Border CornerRadius="8" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- 预览工具栏 -->
                        <Border Padding="8,4" BorderThickness="0,0,0,1"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                            <Grid>
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <Border Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="2">
                                        <StackPanel Orientation="Horizontal" Spacing="2">
                                            <ToggleButton x:Name="BtnSingleView" Content="单帧" IsChecked="True"
                                                          Click="ToggleSingleView_Click" Padding="8,4" FontSize="12"
                                                          CornerRadius="3" MinWidth="0" MinHeight="0" />
                                            <ToggleButton x:Name="BtnGridView" Content="网格"
                                                          Click="ToggleGridView_Click" Padding="8,4" FontSize="12"
                                                          CornerRadius="3" MinWidth="0" MinHeight="0" />
                                        </StackPanel>
                                    </Border>
                                    <ComboBox x:Name="ResolutionCombo" Margin="8,0,0,0" MinWidth="80" FontSize="12"
                                              SelectedIndex="2" SelectionChanged="Resolution_SelectionChanged"
                                              Visibility="{x:Bind ViewModel.IsSingleView, Mode=OneWay}"
                                              VerticalAlignment="Center" Padding="6,2">
                                        <ComboBoxItem Content="25%" Tag="0.25" />
                                        <ComboBoxItem Content="50%" Tag="0.5" />
                                        <ComboBoxItem Content="100%" Tag="1.0" />
                                        <ComboBoxItem Content="200%" Tag="2.0" />
                                        <ComboBoxItem Content="原始" Tag="0" />
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 单帧预览 -->
                        <Grid Grid.Row="1" Visibility="{x:Bind ViewModel.IsSingleView, Mode=OneWay}">
                            <TextBlock Text="渲染预览" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <Image Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}" Stretch="Uniform">
                                <Image.OpacityTransition>
                                    <ScalarTransition Duration="0:0:0.15" />
                                </Image.OpacityTransition>
                            </Image>
                            <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingPreview, Mode=OneWay}"
                                          Width="40" Height="40"
                                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <!-- 网格缩略图 -->
                        <GridView x:Name="PreviewGridView" Grid.Row="1"
                                  ItemsSource="{x:Bind ViewModel.GridThumbnails, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.IsGridView, Mode=OneWay}"
                                  SelectionMode="Single" IsItemClickEnabled="True" ItemClick="GridThumbnail_Click"
                                  DoubleTapped="GridView_DoubleTapped"
                                  Padding="8" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  SizeChanged="GridView_SizeChanged" Loaded="GridView_Loaded"
                                  PointerWheelChanged="GridView_PointerWheelChanged">
                            <GridView.ItemContainerTransitions>
                                <TransitionCollection><AddDeleteThemeTransition /></TransitionCollection>
                            </GridView.ItemContainerTransitions>
                            <GridView.ItemContainerStyle>
                                <Style TargetType="GridViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0" /><Setter Property="Padding" Value="0" />
                                    <Setter Property="MinWidth" Value="0" /><Setter Property="MinHeight" Value="0" />
                                </Style>
                            </GridView.ItemContainerStyle>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Margin="3" BorderThickness="2"
                                            BorderBrush="{Binding Status, Converter={StaticResource CardBrush}}"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            Opacity="{Binding Status, Converter={StaticResource StatusOpacity}}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" /><RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Border CornerRadius="6" Margin="4,4,4,2"
                                                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                                                <Grid CornerRadius="6">
                                                    <Image Source="{Binding Image}" Stretch="UniformToFill">
                                                        <Image.OpacityTransition>
                                                            <ScalarTransition Duration="0:0:0.15" />
                                                        </Image.OpacityTransition>
                                                    </Image>
                                                    <ProgressRing Width="20" Height="20" IsActive="True"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                  Visibility="{Binding Status, Converter={StaticResource RingVisibility}}" />
                                                </Grid>
                                            </Border>
                                            <Border Grid.Row="1" Padding="0,3"
                                                    Background="{Binding Status, Converter={StaticResource CardBrush}}">
                                                <TextBlock Text="{Binding Label}" FontSize="11"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </Grid>
                </Border>
            </Grid>

            <!-- 帧时间轴 -->
            <Border Grid.Row="2" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="6,4">
                <Grid RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="帧时间轴" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="2,0,0,0"
                                       VerticalAlignment="Center" />
                            <Button Click="TogglePlayback_Click" Padding="4,2"
                                    ToolTipService.ToolTip="播放/停止 (空格)" VerticalAlignment="Center">
                                <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="12" />
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                            <FontIcon Glyph="&#xE71E;" FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                            <Slider x:Name="TimelineZoomSlider" Width="80" Minimum="12" Maximum="80" Value="24"
                                    ValueChanged="TimelineZoom_ValueChanged" VerticalAlignment="Center" />
                            <FontIcon Glyph="&#xE8A3;" FontSize="10" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                    <ScrollViewer x:Name="TimelineScrollViewer" Grid.Row="1"
                                  HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled"
                                  VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled"
                                  Height="72">
                        <Canvas x:Name="TimelineCanvas" Height="52"
                                PointerPressed="TimelineCanvas_PointerPressed"
                                PointerMoved="TimelineCanvas_PointerMoved"
                                PointerReleased="TimelineCanvas_PointerReleased"
                                Background="Transparent" />
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- 日志面板 -->
            <Border Grid.Row="3" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="8"
                    Visibility="{x:Bind ViewModel.ShowLogPanel, Mode=OneWay}" Height="180">
                <Grid RowSpacing="4">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid>
                        <TextBlock Text="日志" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                            <Button Content="清空" FontSize="12" Padding="8,2"
                                    Command="{x:Bind ViewModel.ClearLogCommand}" />
                        </StackPanel>
                    </Grid>
                    <ListView Grid.Row="1" x:Name="LogListView"
                              ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                              FontFamily="Consolas" FontSize="12">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" Padding="0,1">
                                    <TextBlock Text="{Binding TimeText}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{Binding LevelIcon}" />
                                    <TextBlock Text="{Binding Message}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
