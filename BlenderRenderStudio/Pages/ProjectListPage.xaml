<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="BlenderRenderStudio.Pages.ProjectListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:BlenderRenderStudio.Models">

    <Grid Padding="32,24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid>
            <StackPanel>
                <TextBlock Text="项目" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="管理你的 Blender 渲染项目" FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,2,0,0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Style="{StaticResource AccentButtonStyle}" Click="NewProject_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="新建项目" />
                    </StackPanel>
                </Button>
                <Button Click="ImportProject_Click" ToolTipService.ToolTip="从 .brsproj 归档导入项目">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                        <TextBlock Text="导入项目" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 项目卡片网格 -->
        <GridView x:Name="ProjectGrid" Grid.Row="1"
                  ItemsSource="{x:Bind Projects, Mode=OneWay}"
                  SelectionMode="None" IsItemClickEnabled="True"
                  ItemClick="ProjectCard_Click"
                  Padding="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="0,0,12,12" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="280" ItemHeight="200" />
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:RenderProject">
                    <Border CornerRadius="8" BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                        <Border.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="导出项目" Icon="SaveLocal"
                                                Tag="{x:Bind Id}" Click="ExportProject_Click" />
                                <MenuFlyoutItem Text="在文件管理器中打开" Icon="OpenLocal"
                                                Tag="{x:Bind Id}" Click="OpenInExplorer_Click" />
                            </MenuFlyout>
                        </Border.ContextFlyout>
                        <Border.Transitions>
                            <TransitionCollection>
                                <EntranceThemeTransition FromVerticalOffset="40" />
                            </TransitionCollection>
                        </Border.Transitions>
                        <Grid Padding="16,12" RowSpacing="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 项目名称 + 状态 -->
                            <Grid>
                                <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"
                                           TextTrimming="CharacterEllipsis" MaxLines="1" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                    <!-- 渲染状态徽章 -->
                                    <Border CornerRadius="4" Padding="6,2"
                                            Background="#3060A5E0"
                                            Visibility="{x:Bind IsRenderingOrQueued, Mode=OneWay}">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <ProgressRing IsActive="{x:Bind IsRendering, Mode=OneWay}"
                                                          Width="12" Height="12" />
                                            <TextBlock FontSize="10" Text="{x:Bind StatusDisplayText, Mode=OneWay}"
                                                       Foreground="#60A5E0" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="4" Padding="6,2"
                                            Background="{ThemeResource ControlFillColorSecondaryBrush}">
                                        <TextBlock FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind CompletedFrames, Mode=OneWay}" /><Run Text="/" /><Run Text="{x:Bind TotalFrames}" />
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <!-- 文件路径 -->
                            <TextBlock Grid.Row="1" Text="{x:Bind BlendFileName}" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       TextTrimming="CharacterEllipsis" MaxLines="2" />

                            <!-- 进度条 -->
                            <ProgressBar Grid.Row="2" Value="{x:Bind ProgressPercent, Mode=OneWay}" Maximum="100"
                                         Height="4" CornerRadius="2" />

                            <!-- 底部操作 -->
                            <Grid Grid.Row="3">
                                <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="帧 " /><Run Text="{x:Bind StartFrame}" /><Run Text=" - " /><Run Text="{x:Bind EndFrame}" />
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="4">
                                    <Button Padding="4" ToolTipService.ToolTip="加入渲染队列"
                                            Tag="{x:Bind Id}" Click="AddToQueue_Click">
                                        <FontIcon Glyph="&#xE710;" FontSize="12" />
                                    </Button>
                                    <Button Padding="4" ToolTipService.ToolTip="删除项目"
                                            Tag="{x:Bind Id}" Click="DeleteProject_Click">
                                        <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- 空状态 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                    Visibility="{x:Bind IsEmpty, Mode=OneWay}">
            <FontIcon Glyph="&#xE8F1;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="还没有项目" FontSize="16" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="点击「新建项目」或「导入项目」开始" FontSize="13"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
