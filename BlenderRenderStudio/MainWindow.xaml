<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="BlenderRenderStudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:BlenderRenderStudio.ViewModels"
    xmlns:converters="using:BlenderRenderStudio.Converters"
    xmlns:models="using:BlenderRenderStudio.Models"
    xmlns:vm="using:BlenderRenderStudio.ViewModels"
    Title="Blender Render Studio">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <converters:FrameStatusToBrushConverter x:Key="StatusBrush" />
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════ 左侧面板：参数配置 + 控制按钮 ═══════ -->
        <Border Grid.Column="0" BorderThickness="0,0,1,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
            <Grid RowSpacing="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Padding="20,16" Spacing="4">

                        <TextBlock Text="Blender Render Studio" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12" />

                        <!-- ────── 文件与输出 ────── -->
                        <TextBlock Text="文件与输出" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />

                        <!-- Blender 路径 -->
                        <StackPanel Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="Blender 路径" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{x:Bind ViewModel.BlenderPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" FontSize="12" />
                                <Button Grid.Column="1" Content="..." Click="BrowseBlenderPath_Click"
                                        IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>

                        <!-- Blend 文件 -->
                        <StackPanel Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="Blend 文件" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{x:Bind ViewModel.BlendFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="选择 .blend 文件"
                                         IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" FontSize="12" />
                                <Button Grid.Column="1" Content="..." Click="BrowseBlendFile_Click"
                                        IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>

                        <!-- 输出路径 -->
                        <StackPanel Spacing="4" Margin="0,0,0,8">
                            <TextBlock Text="输出路径" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Grid ColumnSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{x:Bind ViewModel.OutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="默认跟随工程目录"
                                         IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" FontSize="12" />
                                <Button Grid.Column="1" Content="..." Click="BrowseOutputPath_Click"
                                        IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>

                        <!-- 输出类型 -->
                        <StackPanel Spacing="4" Margin="0,0,0,4">
                            <TextBlock Text="输出类型" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <ComboBox x:Name="OutputTypeCombo" HorizontalAlignment="Stretch"
                                      SelectedIndex="{x:Bind ViewModel.SelectedOutputTypeIndex, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}">
                                <ComboBoxItem Content="图片序列（逐帧渲染，支持续渲）" />
                                <ComboBoxItem Content="视频（整段渲染为视频文件）" />
                                <ComboBoxItem Content="单帧图片（只渲染一帧）" />
                            </ComboBox>
                        </StackPanel>

                        <MenuFlyoutSeparator Margin="0,8" />

                        <!-- ────── 渲染范围 ────── -->
                        <TextBlock Text="渲染范围" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,8" />

                        <!-- 帧范围（图片序列和视频模式） -->
                        <Grid ColumnSpacing="12" RowSpacing="8"
                              Visibility="{x:Bind ViewModel.ShowFrameRange, Mode=OneWay}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <NumberBox Header="起始帧" Value="{x:Bind ViewModel.StartFrame, Mode=TwoWay}" Minimum="0"
                                       SpinButtonPlacementMode="Inline" SmallChange="1"
                                       IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                            <NumberBox Grid.Column="1" Header="结束帧" Value="{x:Bind ViewModel.EndFrame, Mode=TwoWay}" Minimum="0"
                                       SpinButtonPlacementMode="Inline" SmallChange="1"
                                       IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                        </Grid>

                        <!-- 单帧帧号 -->
                        <NumberBox Header="帧号" Value="{x:Bind ViewModel.SingleFrameNumber, Mode=TwoWay}" Minimum="0"
                                   SpinButtonPlacementMode="Inline" SmallChange="1"
                                   IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.IsSingleFrame, Mode=OneWay}" />

                        <!-- 批大小（仅图片序列） -->
                        <NumberBox Header="批大小" Value="{x:Bind ViewModel.BatchSize, Mode=TwoWay}" Minimum="1" Maximum="9999"
                                   SpinButtonPlacementMode="Inline" SmallChange="10"
                                   IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}"
                                   Visibility="{x:Bind ViewModel.ShowBatchSize, Mode=OneWay}"
                                   Margin="0,8,0,0" />

                        <MenuFlyoutSeparator Margin="0,8" />

                        <!-- ────── 高级设置（可折叠） ────── -->
                        <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                  IsExpanded="False">
                            <Expander.Header>
                                <TextBlock Text="高级设置" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            </Expander.Header>
                            <StackPanel Spacing="12" Padding="0,8">
                                <!-- 内存管理 -->
                                <TextBlock Text="内存管理" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <NumberBox Header="阈值 %" Value="{x:Bind ViewModel.MemoryThreshold, Mode=TwoWay}" Minimum="50" Maximum="99"
                                               SpinButtonPlacementMode="Inline"
                                               IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                    <NumberBox Grid.Column="1" Header="轮询间隔(秒)" Value="{x:Bind ViewModel.MemoryPollSeconds, Mode=TwoWay}"
                                               Minimum="0.5" Maximum="60" SpinButtonPlacementMode="Inline"
                                               IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                </Grid>

                                <!-- 崩溃重启 -->
                                <TextBlock Text="崩溃恢复" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                                <ToggleSwitch Header="崩溃自动重启" IsOn="{x:Bind ViewModel.AutoRestartOnCrash, Mode=TwoWay}"
                                              IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <NumberBox Header="最大重启次数" Value="{x:Bind ViewModel.MaxAutoRestarts, Mode=TwoWay}"
                                               Minimum="0" Maximum="100" SpinButtonPlacementMode="Inline"
                                               IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                    <NumberBox Grid.Column="1" Header="重启延迟(秒)" Value="{x:Bind ViewModel.RestartDelaySeconds, Mode=TwoWay}"
                                               Minimum="1" Maximum="60" SpinButtonPlacementMode="Inline"
                                               IsEnabled="{x:Bind ViewModel.IsNotRendering, Mode=OneWay}" />
                                </Grid>

                                <!-- 黑帧检测 -->
                                <TextBlock Text="黑帧检测" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,4,0,0" />
                                <ToggleSwitch Header="启用黑帧检测" IsOn="{x:Bind ViewModel.EnableBlackFrameDetection, Mode=TwoWay}" />
                                <NumberBox Header="亮度阈值 (0~255)" Value="{x:Bind ViewModel.BlackFrameThreshold, Mode=TwoWay}"
                                           Minimum="0" Maximum="50" SpinButtonPlacementMode="Inline" />
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>

                <!-- 控制按钮固定在底部 -->
                <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        Padding="20,12">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.StartCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE768;" FontSize="14" />
                                <TextBlock Text="开始渲染" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.StopCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE71A;" FontSize="14" />
                                <TextBlock Text="停止" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════ 右侧面板：状态 + 预览 + 帧列表 + 日志 ═══════ -->
        <Grid Grid.Column="1" Padding="20,16" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="200" />
            </Grid.RowDefinitions>

            <!-- ─── 状态区 ─── -->
            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ProgressBar Value="{x:Bind ViewModel.OverallProgress, Mode=OneWay}" Maximum="100" Height="8" CornerRadius="4" />

                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="总进度" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock>
                            <Run Text="{x:Bind ViewModel.OverallProgress, Mode=OneWay}" /><Run Text="%" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="当前帧" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock>
                            <Run Text="{x:Bind ViewModel.CurrentFrame, Mode=OneWay}" /><Run Text=" / " /><Run Text="{x:Bind ViewModel.EndFrame, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="采样" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock>
                            <Run Text="{x:Bind ViewModel.CurrentSample, Mode=OneWay}" /><Run Text=" / " /><Run Text="{x:Bind ViewModel.TotalSamples, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="内存" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock>
                            <Run Text="B:" /><Run Text="{x:Bind ViewModel.BlenderMemory, Mode=OneWay}" />
                            <Run Text=" S:" /><Run Text="{x:Bind ViewModel.SystemMemPhys, Mode=OneWay}" /><Run Text="%" />
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <Grid ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="预计剩余" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.EstimatedRemaining, Mode=OneWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="已完成" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.CompletedFrames, Mode=OneWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="黑帧" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.BlackFrameCount, Mode=OneWay}" Foreground="Orange" />
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="错误帧" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.ErrorFrameCount, Mode=OneWay}" Foreground="Red" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ─── 预览 + 帧列表 ─── -->
            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>

                <!-- 实时预览 -->
                <Border CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <TextBlock Text="渲染预览" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   x:Name="PreviewPlaceholder" />
                        <Image Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}" Stretch="Uniform" />
                    </Grid>
                </Border>

                <!-- 帧结果列表 -->
                <Border Grid.Column="1" CornerRadius="8" BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="8">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="帧结果" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.FrameResults, Mode=OneWay}"
                                  SelectionMode="Single" SelectionChanged="FrameList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="8" Padding="4,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="10" Height="10"
                                                 Fill="{Binding Status, Converter={StaticResource StatusBrush}}" />
                                        <TextBlock Grid.Column="1" Text="{Binding FrameNumber}" FontFamily="Consolas" />
                                        <TextBlock Grid.Column="2" Text="{Binding BrightnessText}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                                        <FontIcon Grid.Column="3" Glyph="{Binding StatusIcon}" FontSize="14" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- ─── 日志面板 ─── -->
            <Border Grid.Row="2" CornerRadius="8" BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="8">
                <Grid RowSpacing="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <TextBlock Text="日志" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Button HorizontalAlignment="Right" Content="清空" FontSize="12" Padding="8,2"
                                Command="{x:Bind ViewModel.ClearLogCommand}" />
                    </Grid>
                    <ListView Grid.Row="1" x:Name="LogListView"
                              ItemsSource="{x:Bind ViewModel.LogEntries, Mode=OneWay}"
                              FontFamily="Consolas" FontSize="12">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" Padding="0,1">
                                    <TextBlock Text="{Binding TimeText}" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{Binding LevelIcon}" />
                                    <TextBlock Text="{Binding Message}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
