                        <Grid.ChildrenTransitions>
                            <TransitionCollection><EntranceThemeTransition /></TransitionCollection>
                        </Grid.ChildrenTransitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>

                        <Border Padding="8,4" Margin="0,0,0,8">
                            <Grid>
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}" CornerRadius="4" Padding="2">
                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                        <ToggleButton x:Name="BtnFullSingleView" Content="单帧" IsChecked="True"
                                                      Click="ToggleSingleView_Click" Padding="8,4" FontSize="12" CornerRadius="3" MinWidth="0" MinHeight="0" />
                                        <ToggleButton x:Name="BtnFullGridView" Content="网格"
                                                      Click="ToggleGridView_Click" Padding="8,4" FontSize="12" CornerRadius="3" MinWidth="0" MinHeight="0" />
                                    </StackPanel>
                                </Border>
                                <Button HorizontalAlignment="Right" Click="ToggleFullscreen_Click" Padding="6,4" ToolTipService.ToolTip="退出全屏">
                                    <FontIcon Glyph="&#xE73F;" FontSize="14" />
                                </Button>
                            </Grid>
                        </Border>

