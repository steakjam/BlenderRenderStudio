                                                        </Border>
                                                        <Border Grid.Row="1" Padding="0,3"
                                                                Background="{Binding Status, Converter={StaticResource CardBrush}}">
                                                            <TextBlock Text="{Binding Label}" FontSize="11"
                                                                       HorizontalAlignment="Center"
                                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </Grid>
                            </Border>
