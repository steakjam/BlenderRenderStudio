                                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                        Opacity="{Binding Status, Converter={StaticResource StatusOpacity}}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*" /><RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <Border CornerRadius="6" Margin="4,4,4,2"
